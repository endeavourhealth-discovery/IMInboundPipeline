import "Utilities.jslt" as utils

{
  "entities" : utils:cleanArray([
    {
      "@id" : formatUuid(.ObservationGuid, "@id"),
      "@type" : "Observation",
      "patient": formatUuid(.PatientGuid, "Patient Guid"),
      "concept": .CodeId,
      "effectiveDate": formatDate("yyyy-MM-dd", .EffectiveDate),
      "numericValue": .Value
    }
  ])
}