import "Utilities.jslt" as utils

{
  "entities" : utils:cleanArray([
    {
      "iri" : formatUuid(.ObservationGuid, "iri"),
      "type" : "Observation",
      "patient" : if (.PatientGuid) formatUuid(.PatientGuid, "Patient Guid"),
      "concept" : "emis_" + .CodeId,
      "effectiveDate" : if (.EffectiveDate) formatDate("yyyy-MM-dd", .EffectiveDate),
      "numericValue" : if (.Value) number(.Value)
    }
  ])
}